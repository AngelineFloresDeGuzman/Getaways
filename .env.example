# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# EmailJS Configuration
VITE_EMAILJS_AUTH_SERVICE_ID=your_emailjs_auth_service_id
VITE_EMAILJS_BOOKING_SERVICE_ID=your_emailjs_booking_service_id
VITE_EMAILJS_AUTH_PUBLIC_KEY=your_emailjs_auth_public_key
VITE_EMAILJS_BOOKING_PUBLIC_KEY=your_emailjs_booking_public_key
VITE_EMAILJS_VERIFY_TEMPLATE_ID=your_emailjs_verify_template_id
VITE_EMAILJS_RESET_TEMPLATE_ID=your_emailjs_reset_template_id
VITE_EMAILJS_BOOKING_SUCCESS_TEMPLATE_ID=your_emailjs_booking_success_template_id
VITE_EMAILJS_CANCELLATION_TEMPLATE_ID=your_emailjs_cancellation_template_id
VITE_EMAILJS_SUBSCRIPTION_SUCCESS_TEMPLATE_ID=your_emailjs_subscription_template_id

# Application Configuration
VITE_SUPPORT_EMAIL=support@getaways.com
VITE_LOGO_URL=https://your-domain.com/logo.jpg

# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Instructions:
# 1. Copy this file to .env (do not commit .env to version control)
# 2. Replace all placeholder values with your actual credentials
# 3. Get Firebase config from: https://console.firebase.google.com/project/_/settings/general
# 4. Get EmailJS config from: https://dashboard.emailjs.com/admin/integration
# 5. Get PayPal Client ID from: https://developer.paypal.com/developer/applications/
# 6. Never share or commit your .env file
