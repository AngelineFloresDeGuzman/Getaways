{
  "name": "getaways-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium WebDriver tests for Getaways Platform",
  "main": "index.js",
  "scripts": {
    "test": "mocha \"**/*.test.js\" --timeout 60000 --recursive",
    "test:auth": "mocha auth/*.test.js --timeout 60000",
    "test:guest": "mocha guest/*.test.js --timeout 60000",
    "test:host": "mocha host/*.test.js --timeout 60000",
    "test:admin": "mocha admin/*.test.js --timeout 60000",
    "test:report": "node generate-report.js",
    "test:all": "npm run test && npm run test:report",
    "screenshot:ide": "node generate-selenium-ide-screenshots.js",
    "screenshot:ide:real": "node generate-realistic-selenium-ide.js",
    "screenshot:edge": "node capture-real-edge-screenshots.js",
    "open:ide": "node open-selenium-ide-edge.js"
  },
  "keywords": [
    "selenium",
    "testing",
    "webdriver"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chai": "^4.3.10",
    "chromedriver": "^142.0.2",
    "fs-extra": "^11.1.1",
    "geckodriver": "^4.0.0",
    "mocha": "^10.2.0",
    "moment": "^2.29.4",
    "selenium-webdriver": "^4.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  }
}
