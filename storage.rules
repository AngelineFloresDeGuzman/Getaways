rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // SECURITY NOTE: Current rules allow public read access for listings and service photos
    // This is intentional for a public-facing marketplace where guests need to view properties
    // If you need to restrict access, change 'allow read: if true;' to 'allow read: if request.auth != null;'
    
    // Allow authenticated users to upload files to messages folder
    match /messages/{conversationId}/{fileName} {
      // Allow read access to authenticated users
      allow read: if request.auth != null;
      
      // Allow write access only to authenticated users
      allow write: if request.auth != null
        && request.resource.size < 30 * 1024 * 1024;  // 30MB max file size for messages
    }
    
    // Allow authenticated users to upload files to their own listings folder
    match /listings/{listingId}/{fileName} {
      // Allow read access to anyone (for viewing listings)
      allow read: if true;
      
      // Allow write access only to authenticated users
      // The user must be authenticated to upload
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10MB max file size
        && request.resource.contentType.matches('image/.*');  // Only images
      
      // Allow delete only to authenticated users
      allow delete: if request.auth != null;
    }
    
    // Allow authenticated users to upload service photos
    match /service-photos/{userId}/{fileName} {
      // Allow read access to anyone (for viewing photos)
      allow read: if true;
      
      // Allow write access only to authenticated users (must be the owner)
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10MB max file size
        && request.resource.contentType.matches('image/.*');  // Only images
      
      // Allow delete only to authenticated users (must be the owner)
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

